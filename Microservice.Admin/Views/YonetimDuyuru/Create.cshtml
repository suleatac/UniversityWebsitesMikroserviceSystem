@model Microservice.Admin.ViewModels.YonetimDuyuru.YonetimDuyuruCreateVm

@{
    ViewBag.pTitle = "Ana Sayfa";
    ViewBag.Title = "Yeni Yönetim Duyurusu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <link href="~/assets/libs/select2/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container--default .select2-selection--single {
            height: calc(1.5em + 0.9rem + 2px) !important;
            border: 1px solid #ced4da !important;
            border-radius: 0.3rem !important;
            padding: 0.45rem 0.9rem !important;
        }

            .select2-container--default .select2-selection--single .select2-selection__rendered {
                line-height: 1.5 !important;
                color: #495057;
            }

            .select2-container--default .select2-selection--single .select2-selection__arrow {
                height: calc(1.5em + 0.9rem + 2px) !important;
            }
    </style>
}

<div class="row justify-content-center">
    <div class="col-xxl-8">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-warning bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3">
                        <div class="avatar-title bg-warning rounded-circle">
                            <i class="mdi mdi-bullhorn fs-5"></i>
                        </div>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">Duyuru Bilgileri</h5>
                        <p class="card-text text-muted mb-0">Yeni bir yönetim duyurusu eklemek için formu doldurun</p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">
                <form asp-action="Create" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert" id="validationSummary">
                        <i class="mdi mdi-block-helper me-2"></i>
                        <ul></ul>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-warning border-bottom pb-2">
                            <i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler
                        </h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Baslik" class="form-label">
                                        Başlık <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-format-title"></i></span>
                                        <input asp-for="Baslik" class="form-control" placeholder="Duyuru başlığı girin" />
                                    </div>
                                    <span asp-validation-for="Baslik" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Olusturan" class="form-label">
                                        Oluşturan Kişi
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-account"></i></span>
                                        <input asp-for="Olusturan" class="form-control" placeholder="Oluşturan kişi" />
                                    </div>
                                    <span asp-validation-for="Olusturan" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Icerik" class="form-label">
                                İçerik <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Icerik" class="form-control" rows="5" placeholder="Duyuru içeriğini girin"></textarea>
                            <span asp-validation-for="Icerik" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-warning">
                            <i class="mdi mdi-content-save me-1"></i> Kaydet
                        </button>
                        <a asp-action="Index" class="btn btn-light ms-2">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/libs/select2/js/select2.min.js"></script>
    <script>
        $(function () {
        $('.select2').select2();
        });
    </script>
}