@model Microservice.Admin.ViewModels.Template.CreateTemplateVm

@{
    ViewBag.pTitle = "Templateler";
    ViewBag.Title = "Yeni Template";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xxl-10">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3">
                        <div class="avatar-title bg-primary rounded-circle">
                            <i class="mdi mdi-file-code fs-5"></i>
                        </div>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">Template Bilgileri</h5>
                        <p class="card-text text-muted mb-0">Yeni bir template oluşturmak için formu doldurun</p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">
                <form asp-action="Create" id="templateCreateForm" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert" id="validationSummary">
                        <i class="mdi mdi-block-helper me-2"></i><ul></ul>
                    </div>

                    <!-- Temel Bilgiler -->
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler
                        </h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="TemplateAdi" class="form-label">Template Adı <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-format-title"></i></span>
                                        <input asp-for="TemplateAdi" class="form-control" placeholder="Template adını giriniz" />
                                    </div>
                                    <span asp-validation-for="TemplateAdi" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="TemplateTuru" class="form-label">Template Türü <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-tag"></i></span>
                                        <input asp-for="TemplateTuru" class="form-control" placeholder="Template türünü giriniz" />
                                    </div>
                                    <span asp-validation-for="TemplateTuru" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Dosya Bilgileri -->
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-folder-outline me-1"></i> Dosya Bilgileri
                        </h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="FolderName" class="form-label">Folder Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-folder"></i></span>
                                        <input asp-for="FolderName" class="form-control" placeholder="Klasör adı" />
                                    </div>
                                    <span asp-validation-for="FolderName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="LayoutPath" class="form-label">Layout Path</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-file-document-outline"></i></span>
                                        <input asp-for="LayoutPath" class="form-control" placeholder="~/Views/Shared/_Layout.cshtml" />
                                    </div>
                                    <span asp-validation-for="LayoutPath" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="mdi mdi-arrow-left me-1"></i> İptal</a>
                        <button type="submit" class="btn btn-primary"><i class="mdi mdi-check me-1"></i> Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
