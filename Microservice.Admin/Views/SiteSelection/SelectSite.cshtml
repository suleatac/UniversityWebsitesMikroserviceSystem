@model Microservice.Admin.ViewModels.SiteSelection.SiteSelectionVm

@{
    ViewData["Title"] = "Site Seçimi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-6 col-md-8 col-sm-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="card-title mb-0">
                    <i class="fas fa-globe me-2"></i> İşlem Yapacağınız Siteyi Seçin
                </h4>
            </div>
            <div class="card-body">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (Model.NoSitesAvailable)
                {
                    <div class="alert alert-warning shadow-sm border-0 rounded-3 p-4" role="alert">

                        @if (Model.IsAdmin)
                        {
                            <div class="d-flex align-items-start">
                                <div class="me-3">
                                    <div class="bg-warning bg-opacity-25 text-warning rounded-circle d-flex align-items-center justify-content-center"
                                         style="width:40px;height:40px;">
                                        <i class="fas fa-exclamation-circle"></i>
                                    </div>
                                </div>

                                <div class="flex-grow-1">
                                    <h5 class="alert-heading mb-2 fw-semibold">
                                        Henüz hiç site eklenmemiş
                                    </h5>

                                    <p class="mb-3 text-muted">
                                        Devam edebilmek için sistemde en az bir site oluşturmanız gerekiyor.
                                    </p>

                                    <a href="@Url.Action("Create", "Site")"
                                       class="btn btn-primary btn-sm px-3 rounded-pill">
                                        <i class="fas fa-plus me-1"></i>
                                        Yeni Site Ekle
                                    </a>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex align-items-start gap-3 p-3 rounded-3 bg-light border">

                                <div class="flex-shrink-0">
                                    <div class="bg-warning bg-opacity-25 text-warning rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                                         style="width:44px;height:44px;">
                                        <i class="fas fa-exclamation-triangle"></i>
                                    </div>
                                </div>

                                <div class="flex-grow-1">
                                    <h5 class="mb-2 fw-semibold text-dark">
                                        Yetkili siteniz bulunmamaktadır
                                    </h5>

                                    <p class="mb-0 text-muted lh-base">
                                        İşlem yapabileceğiniz bir site bulunamadı. Lütfen sistem yöneticinizle iletişime geçiniz.
                                    </p>
                                </div>

                            </div>
                        }

                    </div>
                }
                else
                {
                    <p class="text-muted mb-3">
                        <i class="fas fa-info-circle me-1"></i>
                        @if (Model.IsAdmin)
                        {
                            <span>Devam edebilmek için işlem yapmak istediğiniz siteyi seçmeniz gerekmektedir.</span>
                        }
                        else
                        {
                            <span>Yetkili olduğunuz sitelerden birini seçmeniz gerekmektedir.</span>
                        }
                    </p>

                    @if (!Model.IsAdmin && Model.AuthorizedSiteIds.Any())
                    {
                        <div class="alert alert-info mb-3">
                            <i class="fas fa-lock me-1"></i> Sadece yetkili olduğunuz siteleri görebilirsiniz.
                        </div>
                    }

                    <form asp-action="SelectSite" asp-controller="SiteSelection" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="siteId" class="form-label fw-semibold">
                                <i class="fas fa-globe me-1"></i> Site Seçimi
                            </label>
                            <select name="siteId" id="siteId" class="form-select form-select-lg" required>
                                <option value="" disabled selected>-- Lütfen bir site seçiniz --</option>
                                @foreach (var site in Model.Sites)
                                {
                                    <option value="@site.Id">@site.SiteAdi</option>
                                }
                            </select>
                            <div class="invalid-feedback">
                                Lütfen bir site seçiniz.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="dilId" class="form-label fw-semibold">
                                <i class="fas fa-language me-1"></i> Dil Seçimi
                            </label>
                            <select name="dilId" id="dilId" class="form-select">
                                @foreach (var dil in Model.Diller)
                                {
                                    <option value="@dil.Id" selected="@(dil.Id == Model.CurrentDilId)">@dil.Ad</option>
                                }
                            </select>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-check me-1"></i> Devam Et
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>

        @if (!Model.NoSitesAvailable && Model.IsAdmin)
        {
            <div class="text-center mt-3">
                <a href="@Url.Action("Create", "Site")" class="text-muted">
                    <i class="fas fa-plus me-1"></i> Yeni Site Ekle
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Form validation
        (function() {
            var form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function(e) {
                    var siteSelect = document.getElementById('siteId');
                    if (!siteSelect.value || siteSelect.value === '') {
                        e.preventDefault();
                        siteSelect.classList.add('is-invalid');
                        return;
                    }
                    siteSelect.classList.remove('is-invalid');
                });

                var siteSelect = document.getElementById('siteId');
                if (siteSelect) {
                    siteSelect.addEventListener('change', function() {
                        if (this.value && this.value !== '') {
                            this.classList.remove('is-invalid');
                            this.classList.add('is-valid');
                        }
                    });
                }
            }
        })();
    </script>
}