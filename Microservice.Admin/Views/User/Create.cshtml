@model Microservice.Admin.ViewModels.User.UserAddVm

@{
    ViewBag.pTitle = "Ana Sayfa";
    ViewBag.Title = "Yeni Kullanıcı";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <style>
        .page-header-card {
            background: linear-gradient(135deg, #6f42c1 0%, #d63384 100%);
            border-radius: 12px;
            padding: 1.5rem;
            color: white;
            margin-bottom: 1.5rem;
            box-shadow: 0 4px 12px rgba(111, 66, 193, 0.2);
        }

            .page-header-card h4 {
                font-weight: 600;
                margin-bottom: 0.25rem;
            }

            .page-header-card .breadcrumb {
                background: transparent;
                padding: 0;
                margin: 0;
            }

                .page-header-card .breadcrumb-item a {
                    color: rgba(255, 255, 255, 0.9);
                    text-decoration: none;
                }

                    .page-header-card .breadcrumb-item a:hover {
                        color: #ffffff;
                    }

                .page-header-card .breadcrumb-item.active {
                    color: rgba(255, 255, 255, 0.8);
                }
        .validation-summary-valid {
            display: none !important;
        }
    </style>
}

<!-- Page Header -->
<div class="page-header-card">
    <div class="d-flex align-items-center">
        <div>
            <h4><i class="mdi mdi-account-plus me-2"></i>Yeni Kullanıcı Oluştur</h4>
            <p class="mb-0 opacity-75">Yeni bir kullanıcı hesabı oluşturmak için formu doldurun</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-xxl-8">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3">
                        <div class="avatar-title bg-primary rounded-circle">
                            <i class="mdi mdi-account-plus fs-5"></i>
                        </div>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">Kullanıcı Bilgileri</h5>
                        <p class="card-text text-muted mb-0">Yeni kullanıcı hesabı bilgilerini girin</p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">
                <form asp-action="Create" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert">
                        <i class="mdi mdi-block-helper me-2"></i>
                    </div>

                    <!-- Kullanıcı Bilgileri -->
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler
                        </h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="UserName" class="form-label">
                                        Kullanıcı Adı <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-account"></i></span>
                                        <input asp-for="UserName" class="form-control" placeholder="Kullanıcı adı girin" />
                                    </div>
                                    <span asp-validation-for="UserName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label">
                                        E-Posta <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-email"></i></span>
                                        <input asp-for="Email" class="form-control" placeholder="ornek@email.com" />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="FirstName" class="form-label">
                                        Ad <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-card-account-details"></i></span>
                                        <input asp-for="FirstName" class="form-control" placeholder="Ad girin" />
                                    </div>
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="LastName" class="form-label">
                                        Soyad <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-card-account-details"></i></span>
                                        <input asp-for="LastName" class="form-control" placeholder="Soyad girin" />
                                    </div>
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Personel ve Şifre -->
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-lock-outline me-1"></i> Personel ve Şifre
                        </h6>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="PersonId" class="form-label">
                                        Personel ID <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-identifier"></i></span>
                                        <input asp-for="PersonId" class="form-control" placeholder="Personel ID" />
                                    </div>
                                    <span asp-validation-for="PersonId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label">
                                        Şifre <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-lock"></i></span>
                                        <input asp-for="Password" class="form-control" type="password" placeholder="Şifre girin" id="passwordInput" />
                                        <span class="input-group-text" id="togglePassword" style="cursor: pointer;">
                                            <i class="mdi mdi-eye-off" id="toggleIcon"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="PasswordConfirm" class="form-label">
                                        Şifre Tekrar <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-lock-check"></i></span>
                                        <input asp-for="PasswordConfirm" class="form-control" type="password" placeholder="Şifre tekrar" id="passwordConfirmInput" />
                                        <span class="input-group-text" id="togglePasswordConfirm" style="cursor: pointer;">
                                            <i class="mdi mdi-eye-off" id="toggleIconConfirm"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="PasswordConfirm" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Form Actions -->
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="mdi mdi-arrow-left me-1"></i> İptal
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="mdi mdi-content-save me-1"></i> Kullanıcı Oluştur
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        // Şifre göster/gizle
        document.getElementById('togglePassword').addEventListener('click', function () {
            var passwordInput = document.getElementById('passwordInput');
            var icon = document.getElementById('toggleIcon');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('mdi-eye-off');
                icon.classList.add('mdi-eye');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('mdi-eye');
                icon.classList.add('mdi-eye-off');
            }
        });

        document.getElementById('togglePasswordConfirm').addEventListener('click', function () {
            var passwordInput = document.getElementById('passwordConfirmInput');
            var icon = document.getElementById('toggleIconConfirm');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('mdi-eye-off');
                icon.classList.add('mdi-eye');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('mdi-eye');
                icon.classList.add('mdi-eye-off');
            }
        });

    </script>
}