@model Microservice.Admin.ViewModels.User.UserUpdateVm

@{
    ViewBag.pTitle = "Ana Sayfa";
    ViewBag.Title = "Kullanıcı Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <style>
        .page-header-card {
            background: linear-gradient(135deg, #6f42c1 0%, #d63384 100%);
            border-radius: 12px;
            padding: 1.5rem;
            color: white;
            margin-bottom: 1.5rem;
            box-shadow: 0 4px 12px rgba(111, 66, 193, 0.2);
        }

            .page-header-card h4 {
                font-weight: 600;
                margin-bottom: 0.25rem;
            }

            .page-header-card .breadcrumb {
                background: transparent;
                padding: 0;
                margin: 0;
            }

                .page-header-card .breadcrumb-item a {
                    color: rgba(255, 255, 255, 0.9);
                    text-decoration: none;
                }

                    .page-header-card .breadcrumb-item a:hover {
                        color: #ffffff;
                    }

                .page-header-card .breadcrumb-item.active {
                    color: rgba(255, 255, 255, 0.8);
                }
        .validation-summary-valid {
            display: none !important;
        }
        .role-section {
            max-height: 250px;
            overflow-y: auto;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 0.75rem;
        }
        .role-item {
            padding: 0.35rem 0;
        }
        .role-item label {
            cursor: pointer;
            user-select: none;
        }
        .assigned-role-badge {
            background-color: #198754;
            color: white;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            margin-left: 0.5rem;
        }
    </style>
}

<!-- Page Header -->
<div class="page-header-card">
    <div class="d-flex align-items-center">
        <div>
            <h4><i class="mdi mdi-account-edit me-2"></i>Kullanıcı Düzenle</h4>
            <p class="mb-0 opacity-75">Kullanıcı bilgilerini ve rollerini güncelleyin</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-xxl-8">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-warning bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3">
                        <div class="avatar-title bg-warning rounded-circle">
                            <i class="mdi mdi-account-edit fs-5"></i>
                        </div>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">Kullanıcı Bilgilerini Düzenle</h5>
                        <p class="card-text text-muted mb-0">ID: <code>@Model.Id</code></p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">
                <form asp-action="Edit" class="needs-validation" novalidate>
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert">
                        <i class="mdi mdi-block-helper me-2"></i>
                    </div>

                    <!-- Kullanıcı Bilgileri -->
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler
                        </h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="FirstName" class="form-label">
                                        Ad <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-card-account-details"></i></span>
                                        <input asp-for="FirstName" class="form-control" placeholder="Ad girin" />
                                    </div>
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="LastName" class="form-label">
                                        Soyad <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-card-account-details"></i></span>
                                        <input asp-for="LastName" class="form-control" placeholder="Soyad girin" />
                                    </div>
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label">
                                        E-Posta <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-email"></i></span>
                                        <input asp-for="Email" class="form-control" placeholder="ornek@email.com" />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Enabled" class="form-label">
                                        Durum
                                    </label>
                                    <div class="form-check form-switch form-switch-lg mt-2">
                                        <input asp-for="Enabled" class="form-check-input" type="checkbox" role="switch" />
                                        <label asp-for="Enabled" class="form-check-label ms-2">
                                            @(Model.Enabled ? "Aktif" : "Pasif")
                                        </label>
                                    </div>
                                    <span asp-validation-for="Enabled" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Rol Yönetimi -->
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-shield-account me-1"></i> Rol Yönetimi
                        </h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-success">
                                        <i class="mdi mdi-check-circle me-1"></i> Mevcut Roller
                                    </label>
                                    <p class="text-muted small mb-2">Kullanıcının şu anda sahip olduğu roller. Kaldırmak istediklerinizin işaretini kaldırın.</p>
                                    @if (Model.AssignedRoles != null && Model.AssignedRoles.Any())
                                    {
                                        <div class="role-section border-success">
                                            @for (int i = 0; i < Model.AssignedRoles.Count; i++)
                                            {
                                                <div class="role-item">
                                                    <div class="form-check">
                                                        <input type="checkbox"
                                                               name="SelectedRoles"
                                                               value="@Model.AssignedRoles[i].Name"
                                                               class="form-check-input"
                                                               id="assigned_role_@i"
                                                               checked="checked" />
                                                        <label class="form-check-label" for="assigned_role_@i">
                                                            <span class="badge bg-success me-1"><i class="mdi mdi-check"></i></span>
                                                            @Model.AssignedRoles[i].Name
                                                            @if (!string.IsNullOrEmpty(Model.AssignedRoles[i].Description))
                                                            {
                                                                <small class="text-muted ms-1">- @Model.AssignedRoles[i].Description</small>
                                                            }
                                                        </label>
                                                    </div>
                                                </div>
                                                <input type="hidden" name="AssignedRoles[@i].Id" value="@Model.AssignedRoles[i].Id" />
                                                <input type="hidden" name="AssignedRoles[@i].Name" value="@Model.AssignedRoles[i].Name" />
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-light mb-0">
                                            <i class="mdi mdi-information me-1"></i> Kullanıcının henüz atanmış rolü yok.
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-info">
                                        <i class="mdi mdi-plus-circle me-1"></i> Kullanılabilir Roller
                                    </label>
                                    <p class="text-muted small mb-2">Kullanıcıya eklemek istediğiniz rolleri işaretleyin.</p>
                                    @if (Model.AvailableRoles != null && Model.AvailableRoles.Any())
                                    {
                                        <div class="role-section border-info">
                                            @for (int i = 0; i < Model.AvailableRoles.Count; i++)
                                            {
                                                <div class="role-item">
                                                    <div class="form-check">
                                                        <input type="checkbox"
                                                               name="SelectedRoles"
                                                               value="@Model.AvailableRoles[i].Name"
                                                               class="form-check-input"
                                                               id="available_role_@i" />
                                                        <label class="form-check-label" for="available_role_@i">
                                                            <span class="badge bg-info me-1"><i class="mdi mdi-plus"></i></span>
                                                            @Model.AvailableRoles[i].Name
                                                            @if (!string.IsNullOrEmpty(Model.AvailableRoles[i].Description))
                                                            {
                                                                <small class="text-muted ms-1">- @Model.AvailableRoles[i].Description</small>
                                                            }
                                                        </label>
                                                    </div>
                                                </div>
                                                <input type="hidden" name="AvailableRoles[@i].Id" value="@Model.AvailableRoles[i].Id" />
                                                <input type="hidden" name="AvailableRoles[@i].Name" value="@Model.AvailableRoles[i].Name" />
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-light mb-0">
                                            <i class="mdi mdi-information me-1"></i> Kullanıcının atanabileceği ek rol bulunmuyor.
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Form Actions -->
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="mdi mdi-arrow-left me-1"></i> İptal
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="mdi mdi-content-save me-1"></i> Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        // Enabled checkbox toggle label
        document.getElementById('Enabled').addEventListener('change', function () {
            var label = this.parentElement.querySelector('.form-check-label');
            label.textContent = this.checked ? 'Aktif' : 'Pasif';
        });
    </script>
}