@model Microservice.Admin.ViewModels.Dashboard.DashboardViewModel

@{
    ViewBag.Title = "Anasayfa";
    ViewBag.pTitle = "Admin Paneli";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="row">
    <div class="col-xxl-9">

        <div class="row">
            <div class="col-xl-4">
                <div class="card bg-danger-subtle">
                    <div class="card-body">
                        <div class="d-flex">
                            <div class="avatar avatar-sm avatar-label-danger">
                                <i class="mdi mdi-buffer mt-1"></i>
                            </div>
                            <div class="ms-3">
                                <p class="text-danger mb-1">Toplam haber</p>
                                <h4 class="mb-0">@Model.HaberCount</h4>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="card bg-success-subtle">
                    <div class="card-body">
                        <div class="d-flex">
                            <div class="avatar avatar-sm avatar-label-success">
                                <i class="mdi mdi-cash-usd-outline mt-1"></i>
                            </div>
                            <div class="ms-3">
                                <p class="text-success mb-1">Toplam Duyuru</p>
                                <h4 class="mb-0">@Model.DuyuruCount</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="card bg-info-subtle">
                    <div class="card-body">
                        <div class="d-flex">
                            <div class="avatar avatar-sm avatar-label-info">
                                <i class="mdi mdi-webhook mt-1"></i>
                            </div>
                            <div class="ms-3">
                                <p class="text-info mb-1">Toplam etkinlik</p>
                                <h4 class="mb-0">@Model.EtkinlikCount</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- end row -->
        <div class="row">
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">
                        <i class="fas fa-layer-group fs-14 text-muted"></i>
                    </div>
                    <h4 class="card-title mb-0">Toplam Yapılan İşlemler</h4>
                </div><!-- end card header -->

                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-sm-8">
                            <div id="products" data-colors='["--bs-primary"]' class="apex-charts" dir="ltr"></div>
                        </div>
                        <div class="col-sm-4">
                            <div class="d-grid gap-2">
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">48</span>
                                        <span class="text-muted">Pazartesi</span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" style="width: 48%;"></div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">100</span>
                                        <span class="text-muted">Salı</span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-secondary" style="width: 100%;"></div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">40</span>
                                        <span class="text-muted">Çarşamba</span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-danger" style="width: 40%;"></div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">68</span>
                                        <span class="text-muted">Perşembe</span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" style="width: 68%;"></div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">56</span>
                                        <span class="text-muted">Cuma</span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" style="width: 56%;"></div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">80</span>
                                        <span class="text-muted">Cumartesi</span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning" style="width: 80%;"></div>
                                    </div>
                                </div>

                                <div class="">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">80</span>
                                        <span class="text-muted">Pazar</span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-dark" style="width: 92%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!-- end card-body -->
            </div>
        </div>
    </div>

    <div class="col-xxl-3">
        <div class="row">
            <div class="col-xxl-12 order-4 order-xxl-2">
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon text-muted"><i class="fa fa-bell"></i></div>
                        <h3 class="card-title">Yönetimden Duyurular</h3>
                    </div>
                    <div class="card-body">
                        <div class="rich-list rich-list-bordered rich-list-action">
                            @if (Model.RecentYonetimDuyurular.Any())
                            {
                                foreach (var duyuru in Model.RecentYonetimDuyurular)
                                {
                                    <div class="rich-list-item" role="button" onclick="duyuruDetayGoster(@duyuru.Id)" style="cursor:pointer;">
                                        <div class="rich-list-prepend">
                                            <div class="avatar avatar-xs avatar-label-info">
                                                <div class=""><i class="fa fa-bullhorn"></i></div>
                                            </div>
                                        </div>
                                        <div class="rich-list-content">
                                            <h4 class="rich-list-title mb-1">@duyuru.Baslik</h4>
                                            <p class="rich-list-subtitle mb-0">@duyuru.Icerik</p>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="rich-list-item">
                                    <div class="rich-list-content text-center">
                                        <p class="rich-list-subtitle mb-0 text-muted">Henüz duyuru bulunmamaktadır.</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xxl-12 order-3">
                <div class="card" style="overflow-y: auto; height: 313px;" data-simplebar="">
                    <div class="card-header card-header-bordered">
                        <div class="card-icon text-muted"><i class="fa fa-clipboard-list fs-14"></i></div>
                        <h3 class="card-title">Yapılan son aktiviteler</h3>
                        <div class="card-addon">
                            <button class="btn btn-sm btn-label-primary">See all</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="timeline timeline-timed">
                            <div class="timeline-item">
                                <span class="timeline-time">10:00</span>
                                <div class="timeline-pin"><i class="marker marker-circle text-primary"></i></div>
                                <div class="timeline-content">
                                    <div>
                                        <span>Meeting with</span>
                                        <div class="avatar-group ms-2">
                                            <div class="avatar avatar-circle">
                                                <img src="~/assets/images/users/avatar-1.png" alt="Avatar image" class="avatar-2xs" />
                                            </div>
                                            <div class="avatar avatar-circle">
                                                <img src="~/assets/images/users/avatar-2.png" alt="Avatar image" class="avatar-2xs" />
                                            </div>
                                            <div class="avatar avatar-circle">
                                                <img src="~/assets/images/users/avatar-3.png" alt="Avatar image" class="avatar-2xs" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="timeline-item">
                                <span class="timeline-time">14:00</span>
                                <div class="timeline-pin"><i class="marker marker-circle text-danger"></i></div>
                                <div class="timeline-content">
                                    <p class="mb-0">Received a new feedback on <a href="#">GoFinance</a> App product.</p>
                                </div>
                            </div>
                            <div class="timeline-item">
                                <span class="timeline-time">15:20</span>
                                <div class="timeline-pin"><i class="marker marker-circle text-success"></i></div>
                                <div class="timeline-content">
                                    <p class="mb-0">Lorem ipsum dolor sit amit,consectetur eiusmdd tempor incididunt ut labore et dolore magna.</p>
                                </div>
                            </div>
                            <div class="timeline-item">
                                <span class="timeline-time">17:00</span>
                                <div class="timeline-pin"><i class="marker marker-circle text-info"></i></div>
                                <div class="timeline-content">
                                    <p class="mb-0">Make Deposit <a href="#">USD 700</a> o ESL.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
         
        </div>
    </div>
</div>
<!-- end row -->

<!-- Duyuru Detay Modal -->
<div class="modal fade" id="duyuruDetayModal" tabindex="-1" aria-labelledby="duyuruDetayModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-info">
                <h5 class="modal-title text-white" id="duyuruDetayModalLabel">
                    <i class="far fa-bell me-2"></i> Duyuru Detayı
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="duyuruDetayLoading" class="text-center py-4">
                    <div class="spinner-border text-info" role="status">
                        <span class="visually-hidden">Yükleniyor...</span>
                    </div>
                    <p class="mt-2 text-muted">Duyuru detayı yükleniyor...</p>
                </div>
                <div id="duyuruDetayContent" style="display:none;">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Başlık</label>
                        <h4 id="detayBaslik" class="text-info"></h4>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">İçerik</label>
                        <p id="detayIcerik" class="text-muted" style="white-space: pre-wrap;"></p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Yayınlanma Tarihi</label>
                        <p id="detayTarih" class="text-muted"></p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Durum</label>
                        <p><span id="detayOkunduBadge" class="badge"></span></p>
                    </div>
                </div>
                <div id="duyuruDetayError" style="display:none;">
                    <div class="alert alert-danger text-center" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <span id="detayErrorMessage">Duyuru detayı yüklenirken bir hata oluştu.</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section scripts {

    <script src="~/assets/libs/apexcharts/apexcharts.min.js"></script>

    <script src="~/assets/js/pages/dashboard.init.js"></script>

    <!-- App js -->
    <script src="~/assets/js/app.js"></script>

    <script>
        function duyuruDetayGoster(id) {
            // Modalı göster
            var modal = new bootstrap.Modal(document.getElementById('duyuruDetayModal'));
            
            // Loading göster, içerik gizle
            document.getElementById('duyuruDetayLoading').style.display = 'block';
            document.getElementById('duyuruDetayContent').style.display = 'none';
            document.getElementById('duyuruDetayError').style.display = 'none';
            
            modal.show();

            // API'den detayı getir
            fetch('/YonetimDuyuru/GetDetail/' + id)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Duyuru detayı alınamadı');
                    }
                    return response.json();
                })
                .then(data => {
                    // Loading gizle, içerik göster
                    document.getElementById('duyuruDetayLoading').style.display = 'none';
                    document.getElementById('duyuruDetayContent').style.display = 'block';

                    // Detay bilgilerini doldur
                    document.getElementById('detayBaslik').textContent = data.baslik || data.Baslik;
                    document.getElementById('detayIcerik').textContent = data.icerik || data.Icerik;
                    
                    var tarih = data.eklenmeTarihi || data.EklenmeTarihi;
                    if (tarih) {
                        var date = new Date(tarih);
                        document.getElementById('detayTarih').textContent = date.toLocaleDateString('tr-TR', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        });
                    }

                    var okunduMu = data.okunduMu || data.OkunduMu;
                    var badge = document.getElementById('detayOkunduBadge');
                    if (okunduMu) {
                        badge.className = 'badge bg-success';
                        badge.textContent = 'Okundu';
                    } else {
                        badge.className = 'badge bg-warning text-dark';
                        badge.textContent = 'Okunmadı';
                    }

                    // Okundu olarak işaretle (arka planda)
                    fetch('/YonetimDuyuru/MarkAsRead/' + id, { method: 'POST' })
                        .then(function(response) {
                            if (response.ok) {
                                // Başarılı - badge'i güncelle
                                badge.className = 'badge bg-success';
                                badge.textContent = 'Okundu';
                            }
                        })
                        .catch(function(error) {
                            console.warn('Okundu işaretlenirken hata:', error);
                        });
                })
                .catch(error => {
                    document.getElementById('duyuruDetayLoading').style.display = 'none';
                    document.getElementById('duyuruDetayError').style.display = 'block';
                    document.getElementById('detayErrorMessage').textContent = error.message || 'Duyuru detayı yüklenirken bir hata oluştu.';
                });
        }
    </script>
}