@model Microservice.Admin.ViewModels.Site.SiteEditVm

@{
    ViewBag.pTitle = "Ana Sayfa";
    ViewBag.Title = "Site Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <link href="~/assets/libs/select2/css/select2.min.css" rel="stylesheet" />
    <style>
        /* Select2 Bootstrap 5 uyumlu stil */
        .select2-container--default .select2-selection--single {
            height: calc(1.5em + 0.9rem + 2px) !important;
            border: 1px solid #ced4da !important;
            border-radius: 0.3rem !important;
            padding: 0.45rem 0.9rem !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 1.5 !important;
            padding-left: 0 !important;
            color: #495057;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: calc(1.5em + 0.9rem + 2px) !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__clear {
            display: none !important;
        }
        .select2-container--default.select2-container--focus .select2-selection--single,
        .select2-container--default.select2-container--open .select2-selection--single {
            border-color: #80bdff !important;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,0.25) !important;
        }
        .select2-container--default .select2-results__option--highlighted[aria-selected] {
            background-color: #556ee6 !important;
        }
        .select2-dropdown {
            border-color: #ced4da !important;
        }
    </style>
}


<div class="row justify-content-center">
    <div class="col-xxl-10">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3">
                        <div class="avatar-title bg-primary rounded-circle">
                            <i class="mdi mdi-web fs-5"></i>
                        </div>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">Site Bilgileri</h5>
                        <p class="card-text text-muted mb-0">Mevcut bir web sitesini düzenlemek için formu doldurun</p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">
                <form asp-action="Edit" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert" id="validationSummary">
                        <i class="mdi mdi-block-helper me-2"></i>
                        <ul></ul>
                    </div>
                    <input type="hidden" asp-for="Site.Id" />
                    <!-- Temel Bilgiler -->
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler
                        </h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.SiteAdi" class="form-label">
                                        Site Adı <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-label"></i></span>
                                        <input asp-for="Site.SiteAdi" class="form-control" placeholder="Örn: Üniversite Ana Site" />
                                    </div>
                                    <span asp-validation-for="Site.SiteAdi" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.SiteAdiEng" class="form-label">
                                        Site Adı (İngilizce)
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-translate"></i></span>
                                        <input asp-for="Site.SiteAdiEng" class="form-control" placeholder="e.g.: University Main Site" />
                                    </div>
                                    <span asp-validation-for="Site.SiteAdiEng" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.SiteUrl" class="form-label">
                                        Site URL <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-link"></i></span>
                                        <input asp-for="Site.SiteUrl" class="form-control" placeholder="https://www.example.com" />
                                    </div>
                                    <span asp-validation-for="Site.SiteUrl" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.SiteAlanAdi" class="form-label">
                                        Site Alan Adı
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-domain"></i></span>
                                        <input asp-for="Site.SiteAlanAdi" class="form-control" placeholder="example.com" />
                                    </div>
                                    <span asp-validation-for="Site.SiteAlanAdi" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Birim ve Template -->
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-puzzle-outline me-1"></i> Birim ve Şablon
                        </h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.BirimId" class="form-label">
                                        <i class="mdi mdi-office-building me-1"></i> Birim <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="Site.BirimId" class="form-select select2"
                                            asp-items="@(new SelectList(Model.Birimler, "Id", "Ad", Model.Site.BirimId))">
                          
                                    </select>
                                    <span asp-validation-for="Site.BirimId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.TemplateId" class="form-label">
                                        <i class="mdi mdi-palette me-1"></i> Template <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="Site.TemplateId" class="form-select select2"
                                            asp-items="@(new SelectList(Model.Templates, "Id", "TemplateAdi", Model.Site.TemplateId))">
               
                                    </select>
                                    <span asp-validation-for="Site.TemplateId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- E-Posta Ayarları -->
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-email-outline me-1"></i> E-Posta Ayarları
                        </h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.SiteEPosta" class="form-label">
                                        E-Posta Adresi
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-email"></i></span>
                                        <input asp-for="Site.SiteEPosta" class="form-control" placeholder="info@example.com" />
                                    </div>
                                    <span asp-validation-for="Site.SiteEPosta" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.SiteEPostaSifre" class="form-label">
                                        E-Posta Şifresi 
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-lock"></i></span>
                                        <input asp-for="Site.SiteEPostaSifre"  class="form-control"
                                               placeholder="Şifre giriniz" id="passwordInput" />
                                        <span class="input-group-text" id="togglePassword" style="cursor: pointer;">
                                            <i class="mdi mdi-eye-off" id="toggleIcon"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="Site.SiteEPostaSifre" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.SiteEPostaHost" class="form-label">
                                        SMTP Host
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-server"></i></span>
                                        <input asp-for="Site.SiteEPostaHost" class="form-control" placeholder="smtp.example.com" />
                                    </div>
                                    <span asp-validation-for="Site.SiteEPostaHost" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Site.SiteEPostaPort" class="form-label">
                                        SMTP Port
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-numeric"></i></span>
                                        <input asp-for="Site.SiteEPostaPort" type="number" class="form-control" placeholder="587" />
                                    </div>
                                    <span asp-validation-for="Site.SiteEPostaPort" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Form Actions -->
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="mdi mdi-arrow-left me-1"></i> Listeye Dön
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="mdi mdi-content-save me-1"></i> Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/assets/libs/select2/js/select2.full.min.js"></script>
    <script src="~/assets/libs/select2/js/i18n/tr.js"></script>
    <script>
        // Validation summary gösterimi
        $(document).ready(function () {
            var validationSummary = $('#validationSummary');
            if (validationSummary.find('li').length > 0 || validationSummary.find('span').length > 0) {
                validationSummary.removeClass('d-none');
            }

            // Select2 başlatma
            $('.select2').select2({
                language: 'tr',
                width: '100%'
            });

            // Password toggle
            document.getElementById('togglePassword').addEventListener('click', function () {
                var passwordInput = document.getElementById('passwordInput');
                var toggleIcon = document.getElementById('toggleIcon');

                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    toggleIcon.classList.remove('mdi-eye-off');
                    toggleIcon.classList.add('mdi-eye');
                } else {
                    passwordInput.type = 'password';
                    toggleIcon.classList.remove('mdi-eye');
                    toggleIcon.classList.add('mdi-eye-off');
                }
            });
        });
    </script>
}
