@model Microservice.Admin.ViewModels.SikcaSorulanSoru.SikcaSorulanSoruDetailVm

@{
    ViewBag.pTitle = "Sıkça Sorulan Sorular";
    ViewBag.Title = "SSS Sil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xxl-8">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-danger bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3"><div class="avatar-title bg-danger rounded-circle"><i class="mdi mdi-delete fs-5"></i></div></div>
                    <div><h5 class="card-title mb-1">SSS Silme Onayı</h5><p class="card-text text-muted mb-0">Bu işlem geri alınamaz!</p></div>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-danger d-flex align-items-center" role="alert">
                    <i class="mdi mdi-alert-circle fs-4 me-2"></i>
                    <div><strong>Dikkat!</strong> Bu soruyu silmek üzeresiniz. Bu işlem geri alınamaz.</div>
                </div>
                <div class="row">
                    <div class="col-md-12"><div class="mb-3"><label class="form-label text-muted small">Soru</label><div class="form-control-plaintext fw-semibold">@Model.Soru</div></div></div>
                </div>
                <div class="row">
                    <div class="col-md-12"><div class="mb-3"><label class="form-label text-muted small">Cevap</label><div class="form-control-plaintext fw-semibold" style="max-height: 150px; overflow-y: auto;">@Model.Cevap</div></div></div>
                </div>
                <div class="row">
                    <div class="col-md-6"><div class="mb-3"><label class="form-label text-muted small">Sıra</label><div class="form-control-plaintext fw-semibold">@Model.Sira</div></div></div>
                    <div class="col-md-6"><div class="mb-3"><label class="form-label text-muted small">Kategori ID</label><div class="form-control-plaintext fw-semibold">@Model.KategoriId</div></div></div>
                </div>
                <form asp-action="DeleteConfirmed" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="mdi mdi-arrow-left me-1"></i> İptal</a>
                        <button type="submit" class="btn btn-danger"><i class="mdi mdi-delete me-1"></i> Sil</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>