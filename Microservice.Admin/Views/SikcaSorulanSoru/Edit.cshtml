@model Microservice.Admin.ViewModels.SikcaSorulanSoru.SikcaSorulanSoruEditIndexVm
@using Microservice.Admin.ViewModels.SikcaSorulanSoru

@{
    ViewBag.pTitle = "Sıkça Sorulan Sorular";
    ViewBag.Title = "SSS Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <link href="~/assets/libs/select2/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container--default .select2-selection--single {
            height: calc(1.5em + 0.9rem + 2px) !important;
            border: 1px solid #ced4da !important;
            border-radius: 0.3rem !important;
            padding: 0.45rem 0.9rem !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 1.5 !important;
            padding-left: 0 !important;
            color: #495057;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: calc(1.5em + 0.9rem + 2px) !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__clear {
            display: none !important;
        }
        .select2-container--default.select2-container--focus .select2-selection--single,
        .select2-container--default.select2-container--open .select2-selection--single {
            border-color: #80bdff !important;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,0.25) !important;
        }
        .select2-container--default .select2-results__option--highlighted[aria-selected] {
            background-color: #17a2b8 !important;
        }
        .select2-dropdown {
            border-color: #ced4da !important;
        }
    </style>
}

<div class="row justify-content-center">
    <div class="col-xxl-8">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-warning bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3"><div class="avatar-title bg-warning rounded-circle"><i class="mdi mdi-pencil-outline fs-5"></i></div></div>
                    <div><h5 class="card-title mb-1">SSS Düzenle</h5><p class="card-text text-muted mb-0">ID: <strong>@Model.SikcaSorulanSoru.Id</strong></p></div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert" id="validationSummary"><i class="mdi mdi-block-helper me-2"></i><ul></ul></div>
                    <input type="hidden" asp-for="SikcaSorulanSoru.Id" />
                    <input type="hidden" asp-for="SikcaSorulanSoru.SiteId" />
                    <input type="hidden" asp-for="SikcaSorulanSoru.DilId" />

    @*                 <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler</h6>
                        <div class="row">
                            
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="SikcaSorulanSoru.Sira" class="form-label">Sıra</label>
                                    <input asp-for="SikcaSorulanSoru.Sira" class="form-control" type="number" min="0" />
                                    <span asp-validation-for="SikcaSorulanSoru.Sira" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div> *@

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-comment-question me-1"></i> Soru ve Cevap</h6>
                        <div class="mb-3">
                            <label asp-for="SikcaSorulanSoru.Soru" class="form-label">Soru <span class="text-danger">*</span></label>
                            <div class="input-group"><span class="input-group-text"><i class="mdi mdi-help-circle-outline"></i></span><input asp-for="SikcaSorulanSoru.Soru" class="form-control" /></div>
                            <span asp-validation-for="SikcaSorulanSoru.Soru" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="SikcaSorulanSoru.Cevap" class="form-label">Cevap <span class="text-danger">*</span></label>
                            <textarea asp-for="SikcaSorulanSoru.Cevap" id="CevapEditor" class="form-control" rows="8"></textarea>
                            <span asp-validation-for="SikcaSorulanSoru.Cevap" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-file-tree-outline me-1"></i> Hiyerarşi</h6>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label asp-for="SikcaSorulanSoru.ParentId" class="form-label">
                                        <i class="mdi mdi-account-tree me-1"></i> Üst Soru (Parent)
                                    </label>
                                    <select asp-for="SikcaSorulanSoru.ParentId" class="form-select select2"
                                            asp-items="@(new SelectList(FlattenSss(Model.SikcaSorulanSorular, Model.SikcaSorulanSoru.Id), "Id", "Ad", Model.SikcaSorulanSoru.ParentId))">
                                        <option value="">Üst soru yok (Kök soru)</option>
                                    </select>
                                    <span asp-validation-for="SikcaSorulanSoru.ParentId" class="text-danger small"></span>
                                    <small class="text-muted">SSS hiyerarşisindeki üst soruyu seçin. Boş bırakılırsa kök soru olur.</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-magnify me-1"></i> SEO</h6>
                        <div class="mb-3">
                            <label asp-for="SikcaSorulanSoru.SeoUrl" class="form-label">SEO URL</label>
                            <input asp-for="SikcaSorulanSoru.SeoUrl" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="mdi mdi-arrow-left me-1"></i> Listeye Dön</a>
                        <button type="submit" class="btn btn-warning"><i class="mdi mdi-check me-1"></i> Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@functions {
    private List<dynamic> FlattenSss(List<GetSikcaSorulanSoruVm> sssList, int? excludeId = null, string prefix = "")
    {
        var result = new List<dynamic>();
        foreach (var m in sssList.OrderBy(m => m.Sira))
        {
            // Düzenlenen kaydın kendini parent olarak seçmesini engelle
            if (excludeId.HasValue && m.Id == excludeId.Value) continue;

            result.Add(new { Id = (int?)m.Id, Ad = string.IsNullOrEmpty(prefix) ? m.Soru : prefix + " └ " + m.Soru });
            if (m.Children != null && m.Children.Any())
            {
                result.AddRange(FlattenSss(m.Children, excludeId, string.IsNullOrEmpty(prefix) ? m.Soru : prefix + " └ " + m.Soru));
            }
        }
        return result;
    }
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/assets/libs/select2/js/select2.full.min.js"></script>
    <script src="~/assets/libs/select2/js/i18n/tr.js"></script>
    <script>
        $(document).ready(function () {
            var validationSummary = $('#validationSummary');
            if (validationSummary.find('li').length > 0 || validationSummary.find('span').length > 0) {
                validationSummary.removeClass('d-none');
            }

            $('.select2').select2({
                language: 'tr',
                width: '100%'
            });
        });
    </script>
}
