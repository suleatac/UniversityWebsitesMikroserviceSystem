@model Microservice.Admin.ViewModels.SikcaSorulanSoru.SikcaSorulanSoruDetailVm

@{
    ViewBag.pTitle = "Sıkça Sorulan Sorular";
    ViewBag.Title = "SSS Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xxl-8">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-warning bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3"><div class="avatar-title bg-warning rounded-circle"><i class="mdi mdi-pencil-outline fs-5"></i></div></div>
                    <div><h5 class="card-title mb-1">SSS Düzenle</h5><p class="card-text text-muted mb-0">ID: <strong>@Model.Id</strong></p></div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"><i class="mdi mdi-block-helper me-2"></i><ul></ul></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="SiteId" />
                    <input type="hidden" asp-for="DilId" />

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="KategoriId" class="form-label">Kategori <span class="text-danger">*</span></label>
                                    <select asp-for="KategoriId" class="form-select">
                                        <option value="">-- Kategori Seçin --</option>
                                    </select>
                                    <span asp-validation-for="KategoriId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Sira" class="form-label">Sıra</label>
                                    <input asp-for="Sira" class="form-control" type="number" min="0" />
                                    <span asp-validation-for="Sira" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-comment-question me-1"></i> Soru ve Cevap</h6>
                        <div class="mb-3">
                            <label asp-for="Soru" class="form-label">Soru <span class="text-danger">*</span></label>
                            <div class="input-group"><span class="input-group-text"><i class="mdi mdi-help-circle-outline"></i></span><input asp-for="Soru" class="form-control" /></div>
                            <span asp-validation-for="Soru" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Cevap" class="form-label">Cevap <span class="text-danger">*</span></label>
                            <textarea asp-for="Cevap" id="CevapEditor" class="form-control" rows="8"></textarea>
                            <span asp-validation-for="Cevap" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-magnify me-1"></i> SEO</h6>
                        <div class="mb-3">
                            <label asp-for="SeoUrl" class="form-label">SEO URL</label>
                            <input asp-for="SeoUrl" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="mdi mdi-arrow-left me-1"></i> İptal</a>
                        <button type="submit" class="btn btn-warning"><i class="mdi mdi-check me-1"></i> Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>