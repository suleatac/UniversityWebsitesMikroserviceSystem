@model Microservice.Admin.ViewModels.SikcaSorulanSoru.SikcaSorulanSoruCreateIndexVm

@{
    ViewBag.pTitle = "Sıkça Sorulan Sorular";
    ViewBag.Title = "Yeni Soru";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xxl-8">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-info bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3"><div class="avatar-title bg-info rounded-circle"><i class="mdi mdi-help-circle fs-5"></i></div></div>
                    <div><h5 class="card-title mb-1">Yeni SSS</h5><p class="card-text text-muted mb-0">Yeni bir sıkça sorulan soru oluşturun</p></div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"><i class="mdi mdi-block-helper me-2"></i><ul></ul></div>
                    <input type="hidden" asp-for="CreateSikcaSorulanSoru.SiteId" />
                    <input type="hidden" asp-for="CreateSikcaSorulanSoru.DilId" />

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="CreateSikcaSorulanSoru.KategoriId" class="form-label">Kategori <span class="text-danger">*</span></label>
                                    <select asp-for="CreateSikcaSorulanSoru.KategoriId" class="form-select">
                                        <option value="">-- Kategori Seçin --</option>
                                        @foreach (var kategori in Model.Kategoriler)
                                        {
                                            <option value="@kategori.Id">@kategori.Ad</option>
                                        }
                                    </select>
                                    <span asp-validation-for="CreateSikcaSorulanSoru.KategoriId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="CreateSikcaSorulanSoru.Sira" class="form-label">Sıra</label>
                                    <input asp-for="CreateSikcaSorulanSoru.Sira" class="form-control" type="number" min="0" placeholder="0" />
                                    <span asp-validation-for="CreateSikcaSorulanSoru.Sira" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-comment-question me-1"></i> Soru ve Cevap</h6>
                        <div class="mb-3">
                            <label asp-for="CreateSikcaSorulanSoru.Soru" class="form-label">Soru <span class="text-danger">*</span></label>
                            <div class="input-group"><span class="input-group-text"><i class="mdi mdi-help-circle-outline"></i></span><input asp-for="CreateSikcaSorulanSoru.Soru" class="form-control" placeholder="Soruyu giriniz" /></div>
                            <span asp-validation-for="CreateSikcaSorulanSoru.Soru" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="CreateSikcaSorulanSoru.Cevap" class="form-label">Cevap <span class="text-danger">*</span></label>
                            <textarea asp-for="CreateSikcaSorulanSoru.Cevap" id="CevapEditor" class="form-control" rows="8" placeholder="Cevabı giriniz..."></textarea>
                            <span asp-validation-for="CreateSikcaSorulanSoru.Cevap" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-magnify me-1"></i> SEO</h6>
                        <div class="mb-3">
                            <label asp-for="CreateSikcaSorulanSoru.SeoUrl" class="form-label">SEO URL</label>
                            <input asp-for="CreateSikcaSorulanSoru.SeoUrl" class="form-control" placeholder="seo-url" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="mdi mdi-arrow-left me-1"></i> İptal</a>
                        <button type="submit" class="btn btn-info text-white"><i class="mdi mdi-check me-1"></i> Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>