@model Microservice.Admin.ViewModels.YoneticiSite.YoneticiSiteCreateIndexVm

@{
    ViewBag.pTitle = "Yönetici Siteler";
    ViewBag.Title = "Yeni Yönetici Site";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xxl-10">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3"><div class="avatar-title bg-primary rounded-circle"><i class="mdi mdi-account-plus fs-5"></i></div></div>
                    <div><h5 class="card-title mb-1">Yönetici Site Bilgileri</h5><p class="card-text text-muted mb-0">Yeni bir yönetici site ataması oluşturmak için formu doldurun</p></div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" id="yoneticiSiteCreateForm" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"><i class="mdi mdi-block-helper me-2"></i><ul></ul></div>
                    <input type="hidden" asp-for="CreateYoneticiSite.SiteId" />

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="CreateYoneticiSite.KeycloakUserId" class="form-label">Keycloak UserId <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-key-variant"></i></span>
                                        <input asp-for="CreateYoneticiSite.KeycloakUserId" class="form-control" placeholder="Keycloak kullanıcı ID'sini giriniz" />
                                    </div>
                                    <span asp-validation-for="CreateYoneticiSite.KeycloakUserId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="CreateYoneticiSite.YoneticiTipiId" class="form-label">Yönetici Tipi <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-account-tie"></i></span>
                                        <select asp-for="CreateYoneticiSite.YoneticiTipiId" class="form-select">
                                            <option value="">-- Yönetici Tipi Seçin --</option>
                                            @foreach (var tip in Model.YoneticiTipleri)
                                            {
                                                <option value="@tip.Id">@tip.TipAdi</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="CreateYoneticiSite.YoneticiTipiId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="mdi mdi-arrow-left me-1"></i> İptal</a>
                        <button type="submit" class="btn btn-primary"><i class="mdi mdi-check me-1"></i> Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>