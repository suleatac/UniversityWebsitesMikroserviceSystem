@model Microservice.Admin.ViewModels.YoneticiSite.YoneticiSiteIndexVm

@{
    ViewBag.pTitle = "Yönetici Siteler";
    ViewBag.Title = "Yeni Yönetici Site";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xxl-10">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3"><div class="avatar-title bg-primary rounded-circle"><i class="mdi mdi-account-plus fs-5"></i></div></div>
                    <div><h5 class="card-title mb-1">Yönetici Site Bilgileri</h5><p class="card-text text-muted mb-0">Yeni bir yönetici site ataması oluşturmak için formu doldurun</p></div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" id="yoneticiSiteCreateForm" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"><i class="mdi mdi-block-helper me-2"></i><ul></ul></div>

             
                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler</h6>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label asp-for="YoneticiSite.KeycloakUserId" class="form-label">Keycloak Kullanıcı Seç <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-account-key"></i></span>
                                        <select asp-for="YoneticiSite.KeycloakUserId" class="form-select" id="keycloakUserSelect">
                                            <option value="">-- Kullanıcı Seçin (Opsiyonel) --</option>
                                            @foreach (var user in Model.Users)
                                            {
                                                <option value="@user.Id">@user.UserName - @user.FirstName @user.LastName (@user.Email)</option>
                                            }
                                        </select>
                                    </div>
                                    <div id="adminRoleWarning" class="alert alert-warning mt-2 d-none" role="alert">
                                        <i class="mdi mdi-alert-circle me-1"></i>
                                        <strong>Dikkat!</strong> Bu kullanıcı <span class="badge bg-danger">Admin</span> rolüne sahip. Admin rolündeki kullanıcılar tüm sitelere zaten erişebilir, site ataması gerekli değildir.
                                    </div>
                                    <small class="text-muted">Keycloak kullanıcı seçimi opsiyoneldir. Personel seçimi ile birlikte kullanılabilir.</small>
                                    <span asp-validation-for="YoneticiSite.KeycloakUserId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                 
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="YoneticiSite.YoneticiTipiId" class="form-label">Yönetici Tipi <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-account-tie"></i></span>
                                        <select asp-for="YoneticiSite.YoneticiTipiId" class="form-select">
                                            <option value="">-- Yönetici Tipi Seçin --</option>
                                            @foreach (var tip in Model.YoneticiTipleri)
                                            {
                                                <option value="@tip.Id">@tip.TipAdi</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="YoneticiSite.YoneticiTipiId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="YoneticiSite.SiteId" class="form-label">Yetkili Olacağı Siteyi Seçin <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-home-city"></i></span>
                                        <select asp-for="YoneticiSite.SiteId" class="form-select">
                                            <option value="">-- Site Seçin --</option>
                                            @foreach (var site in Model.TumSiteler)
                                            {
                                                <option value="@site.Id">@site.SiteAdi</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="YoneticiSite.SiteId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

               
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="mdi mdi-arrow-left me-1"></i> İptal</a>
                        <button type="submit" class="btn btn-primary"><i class="mdi mdi-check me-1"></i> Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        document.getElementById('keycloakUserSelect').addEventListener('change', function() {
            var userId = this.value;
            var warningDiv = document.getElementById('adminRoleWarning');

            if (!userId) {
                warningDiv.classList.add('d-none');
                return;
            }

            fetch('/UserRole/IsUserAdmin?userId=' + encodeURIComponent(userId))
                .then(response => response.json())
                .then(data => {
                    if (data.isAdmin) {
                        warningDiv.classList.remove('d-none');
                    } else {
                        warningDiv.classList.add('d-none');
                    }
                })
                .catch(error => {
                    console.error('Admin rol kontrolü sırasında hata oluştu:', error);
                    warningDiv.classList.add('d-none');
                });
        });
    </script>
}
