@model Microservice.Admin.ViewModels.YoneticiSite.YoneticiSiteEditIndexVm

@{
    ViewBag.pTitle = "Yönetici Siteler";
    ViewBag.Title = "Yönetici Site Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xxl-10">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-warning bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3"><div class="avatar-title bg-warning rounded-circle"><i class="mdi mdi-pencil-outline fs-5"></i></div></div>
                    <div><h5 class="card-title mb-1">Yönetici Site Düzenle</h5><p class="card-text text-muted mb-0">ID: <strong>@Model.EditYoneticiSite.Id</strong> | <span class="text-primary">@Model.EditYoneticiSite.KeycloakUserId</span></p></div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" id="EditYoneticiSiteEditForm" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"><i class="mdi mdi-block-helper me-2"></i><ul></ul></div>
                    <input type="hidden" asp-for="EditYoneticiSite.Id" />

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-information-outline me-1"></i> Temel Bilgiler</h6>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label asp-for="EditYoneticiSite.KeycloakUserId" class="form-label">Keycloak Kullanıcı Seç</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-account-key"></i></span>
                                        <select asp-for="EditYoneticiSite.KeycloakUserId" class="form-select" id="keycloakUserSelect">
                                            <option value="">-- Kullanıcı Seçin (Opsiyonel) --</option>
                                            @foreach (var user in Model.Users)
                                            {
                                                var isSelected = user.Id == Model.EditYoneticiSite.KeycloakUserId;
                                                <option value="@user.Id" selected="@(isSelected)">@user.UserName - @user.FirstName @user.LastName (@user.Email)</option>
                                            }
                                        </select>
                                    </div>
                                    <small class="text-muted">Keycloak kullanıcı seçimi opsiyoneldir.</small>
                                    <span asp-validation-for="EditYoneticiSite.KeycloakUserId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="EditYoneticiSite.SiteId" class="form-label">Yetkili Olacağı Siteyi Seçin <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="mdi mdi-home-city"></i></span>
                                        <select asp-for="EditYoneticiSite.SiteId" class="form-select">
                                            <option value="">-- Site Seçin --</option>
                                            @foreach (var site in Model.TumSiteler)
                                            {
                                                <option value="@site.Id" selected="@(site.Id == Model.EditYoneticiSite.SiteId)">@site.SiteAdi</option>
                                            }
                                        </select>
                                    </div>
                                    <span asp-validation-for="EditYoneticiSite.SiteId" class="text-danger small"></span>
                                </div>
                            </div>
                           
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="mdi mdi-arrow-left me-1"></i> İptal</a>
                        <button type="submit" class="btn btn-warning"><i class="mdi mdi-check me-1"></i> Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>