@model Microservice.Admin.ViewModels.SiteOzellikleri.SiteOzellikleriVm

@{
    ViewBag.pTitle = "Site Özellikleri";
    ViewBag.Title = "Yeni Site Özellikleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xxl-10">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3"><div class="avatar-title bg-primary rounded-circle"><i class="mdi mdi-cog-plus fs-5"></i></div></div>
                    <div><h5 class="card-title mb-1">Site Özellikleri Bilgileri</h5><p class="card-text text-muted mb-0">Yeni site özellikleri oluşturmak için formu doldurun</p></div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" id="siteOzellikleriCreateForm" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"><i class="mdi mdi-block-helper me-2"></i><ul></ul></div>
                    <input type="hidden" asp-for="SiteId" />

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-web me-1"></i> Site Adres Bilgileri</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteAdress" class="form-label">Site Adres (TR)</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-web"></i></span><input asp-for="SiteAdress" class="form-control" placeholder="Site adresi (Türkçe)" /></div><span asp-validation-for="SiteAdress" class="text-danger small"></span></div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteAdressEng" class="form-label">Site Adres (EN)</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-web"></i></span><input asp-for="SiteAdressEng" class="form-control" placeholder="Site adresi (İngilizce)" /></div><span asp-validation-for="SiteAdressEng" class="text-danger small"></span></div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteTelNo" class="form-label">Telefon</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-phone"></i></span><input asp-for="SiteTelNo" class="form-control" placeholder="+90..." /></div><span asp-validation-for="SiteTelNo" class="text-danger small"></span></div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteFaxNo" class="form-label">Fax</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-fax"></i></span><input asp-for="SiteFaxNo" class="form-control" placeholder="+90..." /></div><span asp-validation-for="SiteFaxNo" class="text-danger small"></span></div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-information me-1"></i> Hakkımızda Bilgileri</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteBaslangicHakkimizda" class="form-label">Hakkımızda (TR)</label><textarea asp-for="SiteBaslangicHakkimizda" class="form-control" rows="3" placeholder="Hakkımızda metni (Türkçe)"></textarea><span asp-validation-for="SiteBaslangicHakkimizda" class="text-danger small"></span></div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteBaslangicHakkimizdaEng" class="form-label">Hakkımızda (EN)</label><textarea asp-for="SiteBaslangicHakkimizdaEng" class="form-control" rows="3" placeholder="Hakkımızda metni (İngilizce)"></textarea><span asp-validation-for="SiteBaslangicHakkimizdaEng" class="text-danger small"></span></div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteHakkindaLink" class="form-label">Hakkında Link</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-link"></i></span><input asp-for="SiteHakkindaLink" class="form-control" placeholder="https://..." /></div></div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteHakkindaResim" class="form-label">Hakkında Resim</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-image"></i></span><input asp-for="SiteHakkindaResim" class="form-control" placeholder="Resim URL" /></div></div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-share-variant me-1"></i> Sosyal Medya</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3"><label asp-for="SiteFacebookAdress" class="form-label">Facebook</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-facebook"></i></span><input asp-for="SiteFacebookAdress" class="form-control" placeholder="Facebook URL" /></div></div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3"><label asp-for="SiteTwitterAdress" class="form-label">Twitter</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-twitter"></i></span><input asp-for="SiteTwitterAdress" class="form-control" placeholder="Twitter URL" /></div></div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3"><label asp-for="SiteInstagramAdress" class="form-label">Instagram</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-instagram"></i></span><input asp-for="SiteInstagramAdress" class="form-control" placeholder="Instagram URL" /></div></div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3"><label asp-for="SiteYoutubeAdress" class="form-label">YouTube</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-youtube"></i></span><input asp-for="SiteYoutubeAdress" class="form-control" placeholder="YouTube URL" /></div></div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3"><label asp-for="SiteWatsappAdress" class="form-label">WhatsApp</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-whatsapp"></i></span><input asp-for="SiteWatsappAdress" class="form-control" placeholder="WhatsApp URL" /></div></div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3"><label asp-for="SiteLinkedinAdress" class="form-label">LinkedIn</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-linkedin"></i></span><input asp-for="SiteLinkedinAdress" class="form-control" placeholder="LinkedIn URL" /></div></div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-primary border-bottom pb-2"><i class="mdi mdi-video me-1"></i> Video ve Görsel</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteHaritaAdress" class="form-label">Harita Adresi</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-map-marker"></i></span><input asp-for="SiteHaritaAdress" class="form-control" placeholder="Google Maps embed URL" /></div></div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteBaslangicVideoLink" class="form-label">Başlangıç Video Linki</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-video"></i></span><input asp-for="SiteBaslangicVideoLink" class="form-control" placeholder="Video URL" /></div></div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3"><label asp-for="SiteBaslangicVideoResimAdress" class="form-label">Video Resim Adresi</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-image"></i></span><input asp-for="SiteBaslangicVideoResimAdress" class="form-control" placeholder="Resim URL" /></div></div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3"><label asp-for="SiteVideoType" class="form-label">Video Tipi</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-file-video"></i></span><input asp-for="SiteVideoType" class="form-control" placeholder="video/mp4" /></div></div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3"><label asp-for="SiteFooterLogo" class="form-label">Footer Logo</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-image-area"></i></span><input asp-for="SiteFooterLogo" class="form-control" placeholder="Logo URL" /></div></div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3"><label asp-for="SiteTopbarLogo" class="form-label">Topbar Logo</label><div class="input-group"><span class="input-group-text"><i class="mdi mdi-image-area-close"></i></span><input asp-for="SiteTopbarLogo" class="form-control" placeholder="Logo URL" /></div></div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="mdi mdi-arrow-left me-1"></i> İptal</a>
                        <button type="submit" class="btn btn-primary"><i class="mdi mdi-check me-1"></i> Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>