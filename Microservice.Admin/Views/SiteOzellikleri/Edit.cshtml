@model Microservice.Admin.ViewModels.SiteOzellikleri.SiteOzellikleriVm

@{
    ViewBag.pTitle = "Site Özellikleri";
    ViewBag.Title = "Site Özellikleri Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xxl-10">
        <div class="card shadow-lg border-0">

            <div class="card-header bg-warning bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">         
                    <div class="avatar-sm me-3">
                        <div class="avatar-title bg-primary rounded-circle">
                            <i class="mdi mdi-pencil-outline fs-5"></i>
                        </div>
                    </div>
                    <div>
                        <h5 class="card-title mb-1">
                            Site Özellikleri Düzenle
                        </h5>

                        <p class="card-text text-muted mb-0">
                            ID: <strong>@Model.Id</strong>
                        </p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">

                <form asp-action="Edit"
                      id="siteOzellikleriEditForm"
                      class="needs-validation"
                      novalidate>

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger d-none"
                         role="alert"
                         id="validationSummary">

                        <i class="mdi mdi-block-helper me-2"></i>
                        <ul></ul>
                    </div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="SiteId" />

                    <!-- ========================================= -->
                    <!-- Site Adres -->
                    <!-- ========================================= -->

                    <div class="mb-4">

                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-web me-1"></i>
                            Site Adres Bilgileri
                        </h6>

                        <div class="row">

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteAdress" class="form-label">
                                        Site Adres (TR)
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-web"></i>
                                        </span>

                                        <input asp-for="SiteAdress"
                                               class="form-control" />
                                    </div>

                                    <span asp-validation-for="SiteAdress"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteAdressEng" class="form-label">
                                        Site Adres (EN)
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-web"></i>
                                        </span>

                                        <input asp-for="SiteAdressEng"
                                               class="form-control" />
                                    </div>

                                    <span asp-validation-for="SiteAdressEng"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteTelNo" class="form-label">
                                        Telefon
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-phone"></i>
                                        </span>

                                        <input asp-for="SiteTelNo"
                                               class="form-control" />
                                    </div>

                                    <span asp-validation-for="SiteTelNo"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteFaxNo" class="form-label">
                                        Fax
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-fax"></i>
                                        </span>

                                        <input asp-for="SiteFaxNo"
                                               class="form-control" />
                                    </div>

                                    <span asp-validation-for="SiteFaxNo"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- ========================================= -->
                    <!-- Hakkımızda -->
                    <!-- ========================================= -->

                    <div class="mb-4">

                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-information me-1"></i>
                            Hakkımızda Bilgileri
                        </h6>

                        <div class="row">

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteBaslangicHakkimizda"
                                           class="form-label">
                                        Hakkımızda (TR)
                                    </label>

                                    <textarea asp-for="SiteBaslangicHakkimizda"
                                              class="form-control"
                                              rows="3"></textarea>

                                    <span asp-validation-for="SiteBaslangicHakkimizda"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteBaslangicHakkimizdaEng"
                                           class="form-label">
                                        Hakkımızda (EN)
                                    </label>

                                    <textarea asp-for="SiteBaslangicHakkimizdaEng"
                                              class="form-control"
                                              rows="3"></textarea>

                                    <span asp-validation-for="SiteBaslangicHakkimizdaEng"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteHakkindaLink"
                                           class="form-label">
                                        Hakkında Link
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-link"></i>
                                        </span>

                                        <input asp-for="SiteHakkindaLink"
                                               class="form-control" />
                                    </div>

                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteHakkindaResim"
                                           class="form-label">
                                        Hakkında Resim
                                    </label>

                                    <div class="input-group">

                                        <span class="input-group-text">
                                            <i class="mdi mdi-image"></i>
                                        </span>

                                        <input asp-for="SiteHakkindaResim"
                                               class="form-control file-picker-input" />

                                        <button type="button"
                                                class="btn btn-outline-primary open-file-manager"
                                                data-type="image">
                                            <i class="mdi mdi-folder-open-outline"></i>
                                        </button>

                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- ========================================= -->
                    <!-- Sosyal Medya -->
                    <!-- ========================================= -->

                    <div class="mb-4">

                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-share-variant me-1"></i>
                            Sosyal Medya
                        </h6>

                        <div class="row">

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SiteFacebookAdress"
                                           class="form-label">
                                        Facebook
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-facebook"></i>
                                        </span>

                                        <input asp-for="SiteFacebookAdress"
                                               class="form-control" />
                                    </div>

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SiteTwitterAdress"
                                           class="form-label">
                                        Twitter
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-twitter"></i>
                                        </span>

                                        <input asp-for="SiteTwitterAdress"
                                               class="form-control" />
                                    </div>

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SiteInstagramAdress"
                                           class="form-label">
                                        Instagram
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-instagram"></i>
                                        </span>

                                        <input asp-for="SiteInstagramAdress"
                                               class="form-control" />
                                    </div>

                                </div>
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SiteYoutubeAdress"
                                           class="form-label">
                                        YouTube
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-youtube"></i>
                                        </span>

                                        <input asp-for="SiteYoutubeAdress"
                                               class="form-control" />
                                    </div>

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SiteWatsappAdress"
                                           class="form-label">
                                        WhatsApp
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-whatsapp"></i>
                                        </span>

                                        <input asp-for="SiteWatsappAdress"
                                               class="form-control" />
                                    </div>

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SiteLinkedinAdress"
                                           class="form-label">
                                        LinkedIn
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-linkedin"></i>
                                        </span>

                                        <input asp-for="SiteLinkedinAdress"
                                               class="form-control" />
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- ========================================= -->
                    <!-- Video ve Görsel -->
                    <!-- ========================================= -->

                    <div class="mb-4">

                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-video me-1"></i>
                            Video ve Görsel
                        </h6>

                        <div class="row">

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteHaritaAdress"
                                           class="form-label">
                                        Harita Adresi
                                    </label>

                                    <div class="input-group">

                                        <span class="input-group-text">
                                            <i class="mdi mdi-map-marker"></i>
                                        </span>

                                        <input asp-for="SiteHaritaAdress"
                                               class="form-control" />

                                    </div>

                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteBaslangicVideoLink"
                                           class="form-label">
                                        Başlangıç Video Linki
                                    </label>

                                    <div class="input-group">

                                        <span class="input-group-text">
                                            <i class="mdi mdi-video"></i>
                                        </span>

                                        <input asp-for="SiteBaslangicVideoLink"
                                               class="form-control file-picker-input" />

                                        <button type="button"
                                                class="btn btn-outline-primary open-file-manager"
                                                data-type="video">
                                            <i class="mdi mdi-folder-open-outline"></i>
                                        </button>

                                    </div>

                                </div>
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SiteBaslangicVideoResimAdress"
                                           class="form-label">
                                        Video Resim Adresi
                                    </label>

                                    <div class="input-group">

                                        <span class="input-group-text">
                                            <i class="mdi mdi-image"></i>
                                        </span>

                                        <input asp-for="SiteBaslangicVideoResimAdress"
                                               class="form-control file-picker-input" />

                                        <button type="button"
                                                class="btn btn-outline-primary open-file-manager"
                                                data-type="image">
                                            <i class="mdi mdi-folder-open-outline"></i>
                                        </button>

                                    </div>

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SiteVideoType"
                                           class="form-label">
                                        Video Tipi
                                    </label>

                                    <div class="input-group">

                                        <span class="input-group-text">
                                            <i class="mdi mdi-file-video"></i>
                                        </span>

                                        <input asp-for="SiteVideoType"
                                               class="form-control"
                                               placeholder="video/mp4" />

                                    </div>

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SiteFooterLogo"
                                           class="form-label">
                                        Footer Logo
                                    </label>

                                    <div class="input-group">

                                        <span class="input-group-text">
                                            <i class="mdi mdi-image-area"></i>
                                        </span>

                                        <input asp-for="SiteFooterLogo"
                                               class="form-control file-picker-input" />

                                        <button type="button"
                                                class="btn btn-outline-primary open-file-manager"
                                                data-type="image">
                                            <i class="mdi mdi-folder-open-outline"></i>
                                        </button>

                                    </div>

                                </div>
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="SiteTopbarLogo"
                                           class="form-label">
                                        Topbar Logo
                                    </label>

                                    <div class="input-group">

                                        <span class="input-group-text">
                                            <i class="mdi mdi-image-area-close"></i>
                                        </span>

                                        <input asp-for="SiteTopbarLogo"
                                               class="form-control file-picker-input" />

                                        <button type="button"
                                                class="btn btn-outline-primary open-file-manager"
                                                data-type="image">
                                            <i class="mdi mdi-folder-open-outline"></i>
                                        </button>

                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- ========================================= -->
                    <!-- Buttons -->
                    <!-- ========================================= -->

                    <div class="d-flex justify-content-end gap-2">

                        <a asp-action="Index"
                           class="btn btn-secondary">

                            <i class="mdi mdi-arrow-left me-1"></i>
                            İptal
                        </a>

                        <button type="submit"
                                class="btn btn-warning">

                            <i class="mdi mdi-check me-1"></i>
                            Güncelle
                        </button>

                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<!-- ========================================= -->
<!-- File Manager Modal -->
<!-- ========================================= -->

<div class="modal fade"
     id="fileManagerModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    <i class="mdi mdi-folder-open-outline me-1"></i>
                    Dosya Yöneticisi
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body p-0"
                 style="height:600px;">

                <iframe id="fileManagerFrame"
                        src=""
                        style="width:100%; height:100%; border:none;">
                </iframe>

            </div>

        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/js/app.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>

        let currentInput = null;

        // ============================================
        // File Manager
        // ============================================

        $(function () {

            $('.open-file-manager').on('click', function () {

                currentInput = $(this)
                    .closest('.input-group')
                    .find('.file-picker-input');

                let type = $(this).data('type');

                $('#fileManagerFrame').attr(
                    'src',
                    '/File?mode=picker&type=' + type
                );

                $('#fileManagerModal').modal('show');
            });

            // Dosya seçildiğinde
            window.addEventListener('message', function (event) {

                if (event.data.type === 'file-selected') {

                    if (currentInput) {
                        currentInput.val(event.data.url);
                    }

                    $('#fileManagerModal').modal('hide');
                }
            });
        });

        // ============================================
        // Validation Summary
        // ============================================

        $(document).ready(function () {

            var validationSummary = $('#validationSummary');

            if (
                validationSummary.find('li').length > 0 ||
                validationSummary.find('span').length > 0
            ) {
                validationSummary.removeClass('d-none');
            }
        });

    </script>
}
