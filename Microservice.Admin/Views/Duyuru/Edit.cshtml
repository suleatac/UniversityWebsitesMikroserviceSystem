@model Microservice.Admin.ViewModels.Duyuru.DuyuruDetailVm

@{
    ViewBag.pTitle = "Duyurular";
    ViewBag.Title = "Duyuru Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <link href="~/assets/libs/select2/css/select2.min.css" rel="stylesheet" />

    <style>
        .select2-container--default .select2-selection--single {
            height: calc(1.5em + 0.9rem + 2px) !important;
            border: 1px solid #ced4da !important;
            border-radius: 0.375rem !important;
            padding: 0.45rem 0.75rem !important;
            display: flex !important;
            align-items: center !important;
        }

            .select2-container--default .select2-selection--single .select2-selection__rendered {
                color: #495057 !important;
                line-height: normal !important;
                padding-left: 0 !important;
            }

            .select2-container--default .select2-selection--single .select2-selection__arrow {
                height: 100% !important;
            }

            .select2-container--default .select2-selection--single .select2-selection__clear {
                display: none !important;
            }

        .select2-container--default.select2-container--focus .select2-selection--single,
        .select2-container--default.select2-container--open .select2-selection--single {
            border-color: #80bdff !important;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25) !important;
        }

        .select2-dropdown {
            border-color: #ced4da !important;
        }

        .ck-editor__editable {
            min-height: 300px;
        }
    </style>
}

<div class="row justify-content-center">
    <div class="col-xxl-10">
        <div class="card shadow-lg border-0">

            <div class="card-header bg-warning bg-opacity-10 border-bottom">
                <div class="d-flex align-items-center">
                    <div class="avatar-sm me-3">
                        <div class="avatar-title bg-warning rounded-circle">
                            <i class="mdi mdi-pencil-outline fs-5"></i>
                        </div>
                    </div>

                    <div>
                        <h5 class="card-title mb-1">Duyuru Düzenle</h5>
                        <p class="card-text text-muted mb-0">
                            Duyuru ID:
                            <strong>@Model.Id</strong>
                            |
                            <span class="text-primary">@Model.Baslik</span>
                        </p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">

                <form asp-action="Edit"
                      id="duyuruEditForm"
                      class="needs-validation"
                      novalidate>

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger d-none"
                         role="alert"
                         id="validationSummary">
                        <i class="mdi mdi-block-helper me-2"></i>
                        <ul class="mb-0"></ul>
                    </div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="SiteId" />
                    <input type="hidden" asp-for="DilId" />
                    <input type="hidden" asp-for="EklemeTarihi" />
                    <input type="hidden" asp-for="GosterimSayisi" />

                    <!-- Bilgi -->
                    <div class="mb-4">
                        <div class="alert alert-info d-flex align-items-center mb-0" role="alert">
                            <i class="mdi mdi-information-outline me-2 fs-5"></i>

                            <div>
                                <strong>Eklenme Tarihi:</strong>
                                @Model.EklemeTarihi.ToString("dd.MM.yyyy HH:mm")

                                &nbsp;|&nbsp;

                                <strong>Gösterim:</strong>
                                @Model.GosterimSayisi
                            </div>
                        </div>
                    </div>

                    <!-- Temel Bilgiler -->
                    <div class="mb-4">

                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-information-outline me-1"></i>
                            Temel Bilgiler
                        </h6>

                        <div class="row">

                            <div class="col-md-8">
                                <div class="mb-3">

                                    <label asp-for="Baslik" class="form-label">
                                        Başlık
                                        <span class="text-danger">*</span>
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-format-title"></i>
                                        </span>

                                        <input asp-for="Baslik"
                                               class="form-control"
                                               placeholder="Duyuru başlığını giriniz" />
                                    </div>

                                    <span asp-validation-for="Baslik"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="KisaAciklama" class="form-label">
                                        Kısa Açıklama
                                        <span class="text-danger">*</span>
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-text-short"></i>
                                        </span>

                                        <input asp-for="KisaAciklama"
                                               class="form-control"
                                               placeholder="Kısa açıklama" />
                                    </div>

                                    <span asp-validation-for="KisaAciklama"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- İçerik ve Medya -->
                    <div class="mb-4">

                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-file-document-outline me-1"></i>
                            İçerik ve Medya
                        </h6>

                        <div class="mb-3">

                            <label asp-for="IcerikMetni" class="form-label">
                                İçerik Metni
                                <span class="text-danger">*</span>
                            </label>

                            <textarea asp-for="IcerikMetni"
                                      id="IcerikMetniEditor"
                                      class="form-control"
                                      rows="10"
                                      placeholder="Duyuru içeriğini giriniz..."></textarea>

                            <span asp-validation-for="IcerikMetni"
                                  class="text-danger small"></span>
                        </div>

                        <div class="row">

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="Link" class="form-label">
                                        Link
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-link"></i>
                                        </span>

                                        <input asp-for="Link"
                                               class="form-control"
                                               placeholder="https://..." />
                                    </div>

                                    <span asp-validation-for="Link"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">

                                    <label asp-for="ResimUrl" class="form-label">
                                        Resim URL
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="mdi mdi-image"></i>
                                        </span>

                                        <input asp-for="ResimUrl"
                                               class="form-control"
                                               placeholder="Resim URL" />
                                    </div>

                                    <span asp-validation-for="ResimUrl"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Tarih ve Hedef -->
                    <div class="mb-4">

                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-calendar me-1"></i>
                            Tarih ve Hedef
                        </h6>

                        <div class="row">

                            <div class="col-md-3">
                                <div class="mb-3">

                                    <label asp-for="YayimTarihi" class="form-label">
                                        Yayım Tarihi
                                    </label>

                                    <input asp-for="YayimTarihi"
                                           class="form-control"
                                           type="datetime-local" />

                                    <span asp-validation-for="YayimTarihi"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">

                                    <label asp-for="BaslamaTarihi" class="form-label">
                                        Başlama Tarihi
                                    </label>

                                    <input asp-for="BaslamaTarihi"
                                           class="form-control"
                                           type="datetime-local" />

                                    <span asp-validation-for="BaslamaTarihi"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">

                                    <label asp-for="BitisTarihi" class="form-label">
                                        Bitiş Tarihi
                                    </label>

                                    <input asp-for="BitisTarihi"
                                           class="form-control"
                                           type="datetime-local" />

                                    <span asp-validation-for="BitisTarihi"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-3">

                                    <label asp-for="HedefId" class="form-label">
                                        Hedef
                                    </label>

                                    <select asp-for="HedefId"
                                            class="form-select select2">
                                        <option value="">-- Hedef Seçin --</option>
                                    </select>

                                    <span asp-validation-for="HedefId"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- SEO -->
                    <div class="mb-4">

                        <h6 class="text-primary border-bottom pb-2">
                            <i class="mdi mdi-magnify me-1"></i>
                            SEO Bilgileri
                        </h6>

                        <div class="row">

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SeoUrl" class="form-label">
                                        SEO URL
                                    </label>

                                    <input asp-for="SeoUrl"
                                           class="form-control"
                                           placeholder="seo-url" />

                                    <span asp-validation-for="SeoUrl"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SeoTitle" class="form-label">
                                        SEO Title
                                    </label>

                                    <input asp-for="SeoTitle"
                                           class="form-control"
                                           placeholder="SEO başlık" />

                                    <span asp-validation-for="SeoTitle"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">

                                    <label asp-for="SeoDescription" class="form-label">
                                        SEO Description
                                    </label>

                                    <input asp-for="SeoDescription"
                                           class="form-control"
                                           placeholder="SEO açıklama" />

                                    <span asp-validation-for="SeoDescription"
                                          class="text-danger small"></span>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Butonlar -->
                    <div class="d-flex justify-content-end gap-2 pt-3 border-top">

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            <i class="mdi mdi-arrow-left me-1"></i>
                            İptal
                        </a>

                        <button type="submit"
                                class="btn btn-warning">
                            <i class="mdi mdi-check me-1"></i>
                            Güncelle
                        </button>

                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/assets/libs/select2/js/select2.full.min.js"></script>
    <script src="~/assets/libs/select2/js/i18n/tr.js"></script>

    <script>
        $(document).ready(function () {

        // Validation Summary
        const validationSummary = $('#validationSummary');

        if (validationSummary.find('li').length > 0 ||
        validationSummary.find('span').length > 0) {

        validationSummary.removeClass('d-none');
        }

        // Select2
        $('.select2').select2({
        language: 'tr',
        width: '100%',
        placeholder: '-- Hedef Seçin --',
        allowClear: true
        });

        // CKEditor
        if (document.querySelector('#IcerikMetniEditor')) {

        ClassicEditor
        .create(document.querySelector('#IcerikMetniEditor'))
        .catch(error => {
        console.error(error);
        });
        }

        });
    </script>
}