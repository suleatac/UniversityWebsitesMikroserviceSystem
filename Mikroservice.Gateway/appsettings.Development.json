{
  "ReverseProxy": {

    "Routes": {
      "personel-api-route": {
        "ClusterId": "personel.cluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/baskets/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/{version}/personels/{**catch-all}" } ],
        "AuthorizationPolicy": "Password"
      },
      "ogrenci-api-route": {
        "ClusterId": "ogrenci.cluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/ogrencis/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/{version}/ogrencis/{**catch-all}" } ],
        "AuthorizationPolicy": "Password"
      }
    },
    "Clusters": {
      "personel.cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5127/"
          }
        }
      },
      "ogrenci.cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5048/"
          }
        }
      }
    }
  },
  "IpRateLimitPolicies": {
    "IpRules": [
      //{
      //  "Ip": "84.247.85.224",
      //  "Rules": [
      //    {
      //      "Endpoint": "*",
      //      "Period": "1s",
      //      "Limit": 10
      //    },
      //    {
      //      "Endpoint": "*",
      //      "Period": "15m",
      //      "Limit": 200
      //    }
      //  ]
      //},
      //{
      //  "Ip": "192.168.3.22/25",
      //  "Rules": [
      //    {
      //      "Endpoint": "*",
      //      "Period": "1s",
      //      "Limit": 5
      //    },
      //    {
      //      "Endpoint": "*",
      //      "Period": "15m",
      //      "Limit": 150
      //    },
      //    {
      //      "Endpoint": "*",
      //      "Period": "12h",
      //      "Limit": 500
      //    }
      //  ]
      //}
    ]
  },
  "IpRateLimiting": {
    "QuotaExceededResponse": {
      "ContentType": "application/json",
      "Content": "{\"mesaj\": \"İstek limiti aşıldı\",\"Detay\":\"İzin verilen istek sayısı {1}'de {0} istektir. {2} sonra tekrar deneyiniz.\"}"
    },
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "IpWhitelist": [ "127.0.0.1", "::1/10" ], //Örneğin "192.168.0.0/24" adresi gibi, ör. "0.0.0.0/0" tüm IP’ler gibi adres aralıkları da ekleyebilirsiniz.
    //"EndpointWhitelist": [ "*:/api/*" ], //burada tanımlayacağın endpointler muaf olacak
    "ClientWhitelist": [ "internal-service" ], //diğer containerler kısıtlamasız erişebilsin diye ekledik
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 20
      },
      {
        "Endpoint": "*",
        "Period": "15m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "12h",
        "Limit": 1000
      },
      {
        "Endpoint": "*",
        "Period": "7d",
        "Limit": 10000
      }
    ]
  },
  "IdentityOption": {
    "Issuer": "http://localhost:8081/realms/UniversityRealm",
    "Audience": "gateway.api",
    "Adress": "http://localhost:8081/realms/UniversityRealm"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
